datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String           @id @default(uuid())
  username         String           @unique
  passwordHash     String
  passwordPlain    String?
  avatarUrl        String?
  telegramUsername String?
  telegramId       String?          @unique
  role             String           @default("CUSTOMER") // CUSTOMER, STAFF, ADMIN, SUPERADMIN
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  wallet           Wallet?
  orders           Order[]
  disputes         Dispute[]
  depositRequests  DepositRequest[]
}

model Wallet {
  id        String         @id @default(uuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal        @default(0.0) @db.Decimal(12, 2)
  currency  String         @default("USD")
  updatedAt DateTime       @updatedAt
  ledgers   WalletLedger[]

  @@index([userId])
}

model WalletLedger {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String   // DEPOSIT, PURCHASE, REFUND, CREDIT
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  description String
  createdAt   DateTime @default(now())

  @@index([walletId])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String          @id @default(uuid())
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String          @unique
  description String?
  price       Decimal         @db.Decimal(12, 2)
  currency    String          @default("USD")
  formula     String?         // Chemical formula (e.g. NaCl, H2SO4)
  casNumber   String?         // CAS Registry Number for chemicals
  imageUrl    String?         // URL of the product picture
  stockState  String          @default("OUT_OF_STOCK") // IN_STOCK, LOW_STOCK, CRITICAL_STOCK, OUT_OF_STOCK
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       InventoryItem[]
  orderItems  OrderItem[]

  @@index([categoryId])
}

model InventoryItem {
  id           String    @id @default(uuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  data         String    // Batch key, lab locker code, serial, or pickup instructions
  mediaUrl     String?   // URL to image or diagram
  locationData String?   // Coordinates or lab bench pickup location details
  isAllocated  Boolean   @default(false)
  allocatedAt  DateTime?
  createdAt    DateTime  @default(now())
  orderItems   OrderItem[]

  @@index([productId])
  @@index([isAllocated])
}

model Order {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAmount     Decimal        @db.Decimal(12, 2)
  currency        String         @default("USD")
  status          String         @default("PENDING_PAYMENT") // PENDING_PAYMENT, PAYMENT_CONFIRMING, PAID, COMPLETED, REFUNDED, FAILED
  orderSource     String         @default("WEBSITE") // WEBSITE, TELEGRAM
  
  paymentMethod      String         @default("DIRECT_CRYPTO") // WALLET, DIRECT_CRYPTO
  cryptoCurrency     String?        // BTC, ETH, USDT_ERC20, USDT_TRC20, SOL, TRX
  cryptoAmountDue    String?        // Amount customer must send in chosen coin
  networkFee         Decimal?       @db.Decimal(12, 2) // Estimated network fee in USD
  paymentWalletAddress String?      // Specific address customer should pay to
  coinbaseChargeId   String?        
  coinbaseChargeUrl  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  items              OrderItem[]
  disputes           Dispute[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              String         @id @default(uuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  priceAtPurchase Decimal        @db.Decimal(12, 2)
  status          String         @default("PENDING_PAYMENT") // PENDING_PAYMENT, PAID, COOLDOWN_ACTIVE, READY, COMPLETED, REFUNDED, FAILED
  cooldownEndAt   DateTime?
  
  adminMessage    String?
  adminMessageFileUrl  String?
  adminMessageFileType String?
  adminMessageSentAt DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

model Dispute {
  id             String           @id @default(uuid())
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason         String
  status         String           @default("OPEN") // OPEN, INVESTIGATING, RESOLVED
  resolutionType String?          // REFUND, CREDIT, REPLACEMENT, REJECTED
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  messages       DisputeMessage[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model DisputeMessage {
  id         String   @id @default(uuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderRole String   // CUSTOMER or ADMIN
  senderName String
  message    String
  createdAt  DateTime @default(now())

  @@index([disputeId])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model DepositRequest {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(12, 2)
  cryptoCurrency String?  // BTC, ETH, USDT_ERC20, USDT_TRC20, SOL, TRX
  status         String   @default("PENDING") // PENDING, PROCESSING, APPROVED, REJECTED
  txHash         String?  // Transaction hash input by user
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
