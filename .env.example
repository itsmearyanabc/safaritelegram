# Database (local Docker example — see README)
DATABASE_URL="postgresql://safari_user:safari_pass@127.0.0.1:5434/safari_db"

# Session encryption (change in production)
SESSION_SECRET="change-me-to-a-long-random-string"

# Admin control panel (set to false only on a customer-only mirror deploy)
ENABLE_ADMIN=true

# Telegram (from @BotFather)
TELEGRAM_BOT_1_TOKEN=
TELEGRAM_BOT_2_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Public site URL (used by bot deposit button + links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
